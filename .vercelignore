# Vercel only needs the pre-built Flutter web output (build/web/).
# Everything else is excluded to keep the deploy fast.

# Flutter source & tooling
lib/
test/
android/
ios/
linux/
macos/
windows/
.dart_tool/
.flutter-plugins-dependencies
.metadata
pubspec.yaml
pubspec.lock
analysis_options.yaml

# Git
.git/
.gitignore

# IDE
.idea/
*.iml

# Docs
*.md
*.docx
~$*

# Intermediate build artifacts (keep only build/web)
build/app/
build/linux/
build/windows/
build/macos/
build/ios/
